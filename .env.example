# ─────────────────────────────────────────────
#  Audio-to-Mindmap Backend — Environment Variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development          # development | production
APP_DEBUG=true
APP_PORT=8000

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mindmap_db

# ── JWT Auth ─────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080     # 7 days

# ── AI Providers ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...        # Used for Whisper STT

# ── LLM Settings ─────────────────────────────
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.1

# ── Whisper Settings ─────────────────────────
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=auto        # auto | ar | en
AUDIO_CHUNK_MINUTES=10       # chunk long audio every N minutes

# ── File Upload ──────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500
MAX_AUDIO_DURATION_MINUTES=60
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/mp4,audio/ogg,audio/x-m4a

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_UPLOADS_PER_HOUR=3

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Guardrails ───────────────────────────────
MIN_TRANSCRIPT_WORDS=50
HALLUCINATION_THRESHOLD=0.70    # min coverage score to pass
