# ─────────────────────────────────────────────
#  Audio-to-Mindmap Backend — Environment Variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development          # development | production
APP_DEBUG=true
APP_PORT=8000

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mindmap_db

# ── JWT Auth ─────────────────────────────────
# SECURITY: change JWT_SECRET to a long random string before ANY deployment.
# While it equals 'change-me', all auth is bypassed and a demo user is used!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080     # 7 days

# ── AI Providers ─────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ── LLM Settings ─────────────────────────────
LLM_MODEL=gemini-1.5-pro
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.1

# ── Audio Processing ────────────────────────
# Transcription is handled natively by Gemini (no Whisper dependency).
# Known limitation: audio files > ~2 hours may exceed Gemini File API limits.

# ── File Upload ──────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500
MAX_AUDIO_DURATION_MINUTES=60
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/mp4,audio/ogg,audio/x-m4a

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_UPLOADS_PER_HOUR=3

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Guardrails ───────────────────────────────
MIN_TRANSCRIPT_WORDS=50
HALLUCINATION_THRESHOLD=0.70    # min coverage score to pass
